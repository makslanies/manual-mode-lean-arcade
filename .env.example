# Copy to .env for local docker compose / build overrides.
# Vite reads VITE_* at build time only (baked into the static bundle).

# Public URL path when the app is not served from the domain root.
# Example for GitHub Pages: /manual-mode-lean-arcade/
VITE_BASE_URL=/

# Expose window.__RR QA hooks in production builds.
# Set to false for public kiosk deployments.
VITE_ENABLE_DEMO_HOOKS=true

# Reserved for future locale switching (chapter 0 defaults to RU in code).
# VITE_DEFAULT_LOCALE=ru

# --- Docker Compose runtime ---

# Host port mapped to nginx (web service).
PORT=8080

# Host port mapped to Vite dev server (dev profile).
DEV_PORT=5173

# Docker image tag for compose builds.
IMAGE_TAG=local
